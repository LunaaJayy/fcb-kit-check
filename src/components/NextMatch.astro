---
const { match_date, home_img, home_team, away_img, away_team, venue } =
	Astro.props;
---

<section class="match-info">
	<h2>El dia de partit:</h2>
	<p>{venue}</p>
	<p>{match_date}</p>

	<div class="team-block">
		<div class="hometeam">
			<img src={home_img} alt={home_team} />
			<p>{home_team}</p>
		</div>
		<p class="against">v</p>
		<div class="awayteam">
			<img src={away_img} alt={away_team} />
			<p>{away_team}</p>
		</div>
	</div>
	<slot />
</section>

<style>
	p,
	h2,
	h3 {
		text-align: center;
		color: var(--dark-blue);
	}

	.team-block {
		display: flex;
		flex-direction: row;
		justify-content: center;
		align-items: center;
		margin: 1rem 2rem 0;

		p {
			font-size: 0.7rem;
			color: var(--fcb-gold);
		}
		img {
			width: 7rem;
		}
	}

	.against {
		font-family: "transducer", sans-serif;
		font-weight: 100;
		font-style: normal;
		margin: 0 1.5rem;
		color: var(--fcb-gold);
	}
</style>

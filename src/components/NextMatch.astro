---
const {
	match_date,
	home_img,
	home_team,
	away_img,
	away_team,
	venue,
	weather,
	kit_image,
	weather_des,
} = Astro.props;
console.log(kit_image);
---

<section>
	<h2>El dia de partit:</h2>
	<p>{venue}</p>
	<p>{match_date}</p>

	<div class="team-block">
		<div class="hometeam">
			<img src={home_img} alt={home_team} />
			<p>{home_team}</p>
		</div>
		<p class="against">v</p>
		<div class="awayteam">
			<img src={away_img} alt={away_team} />
			<p>{away_team}</p>
		</div>
	</div>
</section>
<section>
	<h2>Weather forecast:</h2>
	<p>{weather}°C</p>
	<p>{weather_des}</p>
	<img src={`/img/kit-${kit_image}.png`} alt="" />
</section>

<style>
	p,
	h2 {
		text-align: center;
	}
	.team-block {
		display: flex;
		flex-direction: row;
		justify-content: center;
		align-items: center;

		p {
			font-size: 0.7rem;
		}
	}

	.against {
		font-family: "transducer", sans-serif;
		font-weight: 100;
		font-style: normal;
	}
	img {
		width: 5rem;
	}
</style>

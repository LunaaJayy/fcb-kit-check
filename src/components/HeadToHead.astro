---
const { wins, draws, losses, goals, goalsAgainst } = Astro.props;
---

<section>
	<h2>Statistics</h2>
	<div class="grid">
		<div>
			<p class="number">{wins}</p>
			<p>Wins</p>
		</div>
		<div>
			<p class="number">{draws}</p>
			<p>Draws</p>
		</div>
		<div>
			<p class="number">{losses}</p>
			<p>Losses</p>
		</div>
		<div>
			<p class="number">{goals}</p>
			<p>Goals For</p>
		</div>
		<div>
			<p class="number">{goalsAgainst}</p>
			<p>Goals Against</p>
		</div>
	</div>
</section>

<style>
	section {
		text-align: center;
		padding: 1rem 0 2rem;
	}

	.grid {
		padding: 1rem 2rem;
		display: grid;
		grid-template: repeat(2, 1fr) / repeat(3, 1fr);
		grid-gap: 1rem;

		div:nth-child(1) {
			grid-area: 1 / 1 / 2 / 2;
		}
		div:nth-child(2) {
			grid-area: 1 / 2 / 2 / 3;
		}
		div:nth-child(3) {
			grid-area: 1 / 3 / 2 / 4;
		}
		div:nth-child(4) {
			grid-area: 2 / 1 / 3 / 3;
		}
		div:nth-child(5) {
			grid-area: 2 / 2 / 3 / 4;
		}
	}

	p {
		color: var(--light-text);
		&:not(.number) {
			font-size: 0.8rem;
		}
	}

	.number {
		font-family: "transducer-condensed", sans-serif;
		font-size: 3.5rem;
	}
</style>

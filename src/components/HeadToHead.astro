---
const { wins, draws, losses, goals, goalsAgainst } = Astro.props;
---

<section>
	<h2>Statistics</h2>
	<div class="grid">
		<div>
			<p class="number">{wins}</p>
			<p>Wins</p>
		</div>
		<div>
			<p class="number">{draws}</p>
			<p>Draws</p>
		</div>
		<div>
			<p class="number">{losses}</p>
			<p>Losses</p>
		</div>
		<div>
			<p class="number">{goals}</p>
			<p>Goals For</p>
		</div>
		<div>
			<p class="number">{goalsAgainst}</p>
			<p>Goals <br />Against</p>
		</div>
	</div>
</section>

<style>
	section {
		text-align: center;
		padding: 1rem 0 2rem;
	}

	.grid {
		padding: 1rem 2rem;
		display: grid;
		grid-template: repeat(2, 1fr) / repeat(6, 1fr);

		div {
			/* https://css-tricks.com/gradient-borders-in-css/ */
			border-width: 1.5px;
			border-style: solid;
			border-image-slice: 1;
			border-image-source: linear-gradient(
				to bottom,
				rgba(0 0 0 / 0) 10%,
				var(--fcb-gold) 45%,
				var(--fcb-gold) 55%,
				rgba(0 0 0 / 0) 90%
			);
			padding: 0.5rem;
		}

		div:nth-child(1) {
			grid-area: 1 / 1 / 2 / 3;
			border-top: 0;
			border-bottom: 0;
			border-left: 0;
		}
		div:nth-child(2) {
			grid-area: 1 / 3 / 2 / 5;
			border-top: 0;
			border-bottom: 0;
			border-left: 0;
		}
		div:nth-child(3) {
			grid-area: 1 / 5 / 2 / 7;
			border: none;
		}
		div:nth-child(4) {
			grid-area: 2 / 2 / 3 / 4;
			border-top: 0;
			border-bottom: 0;
			border-left: 0;
		}
		div:nth-child(5) {
			grid-area: 2 / 4 / 3 / 6;
			border: none;
		}
	}

	p {
		color: var(--light-text);
		&:not(.number) {
			font-size: 0.8rem;
		}
	}

	.number {
		font-family: "transducer-condensed", sans-serif;
		font-size: 3.5rem;
	}
</style>

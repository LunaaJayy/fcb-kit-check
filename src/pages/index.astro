---
// https://claude.ai/share/ff0ad59a-9510-4904-9638-e870e808854d
import { Temporal } from "@js-temporal/polyfill";
import HomeLayout from "../layouts/HomeLayout.astro";
import NextMatch from "./../components/NextMatch.astro";
import Button from "./../components/Button.astro";

// bron: https://claude.ai/share/e1f088ad-72b6-48d3-8a5c-6f2ea805084a
import laLigaLocations from "./../locations.json" assert { type: "json" };
// import wmoDescriptions from "./../descriptions.json" assert { type: "json" };

const wmoDescriptions = {
	"0": "Clear sky",
	"1": "Mainly clear",
	"2": "Partly cloudy",
	"3": "Overcast",
	"45": "Fog",
	"48": "Depositing rime fog",
	"51": "Drizzle: Light",
	"53": "Drizzle: Moderate",
	"55": "Drizzle: Dense",
	"56": "Freezing Drizzle: Light",
	"57": "Freezing Drizzle: Dense",
	"61": "Rain: Slight",
	"63": "Rain: Moderate",
	"65": "Rain: Heavy",
	"66": "Freezing Rain: Light",
	"67": "Freezing Rain: Heavy",
	"71": "Snow fall: Slight",
	"73": "Snow fall: Moderate",
	"75": "Snow fall: Heavy",
	"77": "Snow grains",
	"80": "Rain showers: Slight",
	"81": "Rain showers: Moderate",
	"82": "Rain showers: Violent",
	"85": "Snow showers: Slight",
	"86": "Snow showers: Heavy",
	"95": "Thunderstorm: Slight or moderate",
	"96": "Thunderstorm with slight hail",
	"99": "Thunderstorm with heavy hail",
};

// ------------------------- BARCA API

const barcaBaseURL = "https://api.fc-barcelona.app/api/";

const nextMatchEndpoint = "next-match";
const nextMatchURL = barcaBaseURL + nextMatchEndpoint;
const nextMatchResponse = await fetch(nextMatchURL);
const nextMatchArray = await nextMatchResponse.json();
const nextMatch = nextMatchArray.data;
const nextMatchId = nextMatch.id;

nextMatch.location =
	laLigaLocations[
		nextMatch.homeTeam.toLowerCase().replaceAll(" ", "").replaceAll("é", "e")
	];

console.log(nextMatch);

// ---------- DATE IN WORDS:

const nextMatchDate = nextMatch.matchDate;
const date = Temporal.Instant.from(nextMatchDate)
	.toZonedDateTimeISO("Europe/Amsterdam")
	.toPlainDate();

const day = date.toLocaleString("en-GB", { weekday: "long" });
const month = date.toLocaleString("en-GB", { month: "long" });
const year = date.year;
const ordinal = (n) => {
	const s = ["th", "st", "nd", "rd"];
	const v = n % 100;
	return n + (s[(v - 20) % 10] || s[v] || s[0]);
};

const formatted = `${day}, ${ordinal(date.day)} of ${month} ${year}`;

// ---------- MATCH CALENDAR:

const calendarEndpoint = "calendar?limit=50&offset=0";
const calendarURL = barcaBaseURL + calendarEndpoint;
const calendarResponse = await fetch(calendarURL);
const calendarArray = await calendarResponse.json();
const calendar = calendarArray.data;
const allMatches = calendar.matches;

allMatches.map((match) => {
	match.location =
		laLigaLocations[
			match.homeTeam.toLowerCase().replaceAll(" ", "").replaceAll("é", "e")
		];
});

// console.log(allMatches);

// met behulp van: https://claude.ai/share/25b0ec6a-5a33-48c2-b95c-1ff0eaaf9f9b
let nextMatchCal = allMatches.filter((m) => m.id >= nextMatchId);

const hToHEndpoint = "h2h?team=Real+Madrid";
const hToHURL = barcaBaseURL + hToHEndpoint;
const hToHResponse = await fetch(hToHURL);
const hToHArray = await hToHResponse.json();
const hToH = hToHArray.data;

//console.log(nextMatchCal);
// nextMatchCal.map((item) => console.log(item.matchDate));

// ----------- WEATHER

const lat = nextMatch.location.latitude;
const long = nextMatch.location.longitude;

const weatherUrl = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${long}&daily=weather_code,temperature_2m_max,temperature_2m_min&hourly=temperature_2m,weather_code,apparent_temperature,precipitation&timezone=auto&forecast_days=14`;
const weatherRes = await fetch(weatherUrl);
const weatherData = await weatherRes.json();
// https://open-meteo.com/en/docs?latitude=41.3888&longitude=2.159&forecast_days=14&hourly=temperature_2m,weather_code,apparent_temperature,precipitation&daily=weather_code,temperature_2m_max,temperature_2m_min&timezone=auto

// unknown time
const hourlyWeather = weatherData.hourly;
const dateForWeather = nextMatch.matchDate.slice(0, 10);
const weatherIndexStart = hourlyWeather.time.findIndex((t) =>
	t.startsWith(dateForWeather + "T16"),
);
const weatherIndexEnd = hourlyWeather.time.findIndex((t) =>
	t.startsWith(dateForWeather + "T23"),
);
const gameTemp =
	(Math.round(hourlyWeather.temperature_2m[weatherIndexStart]) +
		Math.round(hourlyWeather.temperature_2m[weatherIndexEnd])) /
	2;
const weatherDesc =
	wmoDescriptions[hourlyWeather.weather_code[weatherIndexStart]];

// ----- KIT KIEZEN
let kitImage = "";

if (gameTemp < 12) {
	kitImage = "vest";
} else if (gameTemp > 18) {
	kitImage = "shortsleeve";
} else {
	kitImage = "longsleeve";
}
---

<HomeLayout title="FC BARCELONA KIT">
	<NextMatch
		match_date={formatted}
		home_img={nextMatch.homeTeamImageUrl}
		home_team={nextMatch.homeTeam}
		away_img={nextMatch.awayTeamImageUrl}
		away_team={nextMatch.awayTeam}
		venue={nextMatch.venue}
		weather={gameTemp}
		weather_des={weatherDesc}
		kit_image={kitImage}>
		<Button href="/h2h" text="See head 2 head" />
	</NextMatch>
</HomeLayout>

<script
	define:vars={{
		nextMatchLocation: nextMatch.location,
		nextMatchDate: nextMatch.matchDate,
		wmoDescriptions,
	}}
>
	async function callWeatherAPI(lat, long) {
		const weatherUrl = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${long}&daily=weather_code,temperature_2m_max,temperature_2m_min&hourly=temperature_2m,weather_code,apparent_temperature,precipitation&timezone=auto&forecast_days=14`;
		const weatherRes = await fetch(weatherUrl);
		const weatherData = await weatherRes.json();
		// https://open-meteo.com/en/docs?latitude=41.3888&longitude=2.159&forecast_days=14&hourly=temperature_2m,weather_code,apparent_temperature,precipitation&daily=weather_code,temperature_2m_max,temperature_2m_min&timezone=auto

		const hourlyWeather = weatherData.hourly;
		const dateForWeather = nextMatchDate.slice(0, 10);
		const weatherIndexStart = hourlyWeather.time.findIndex((t) =>
			t.startsWith(dateForWeather + "T16"),
		);
		const weatherIndexEnd = hourlyWeather.time.findIndex((t) =>
			t.startsWith(dateForWeather + "T23"),
		);
		const gameTemp =
			(Math.round(hourlyWeather.temperature_2m[weatherIndexStart]) +
				Math.round(hourlyWeather.temperature_2m[weatherIndexEnd])) /
			2;
		const weatherDesc =
			wmoDescriptions[hourlyWeather.weather_code[weatherIndexStart]];

		return { weatherData, gameTemp, weatherDesc };
	}

	async function getHomeLocation() {
		return new Promise((success, reject) => {
			navigator.geolocation.getCurrentPosition(
				(position) =>
					success({
						lat: position.coords.latitude,
						long: position.coords.longitude,
					}),
				(error) => reject(error),
			);
		});
	}

	async function handleWeatherData(value) {
		let lat, long;

		if (value === "home") {
			console.log("home selected");
			const homeLocation = await getHomeLocation();
			lat = homeLocation.lat;
			long = homeLocation.long;
			console.log(lat, long);
		} else {
			console.log("live selected");
			lat = nextMatchLocation.latitude; // nextMatchLocation ipv nextMatch.location
			long = nextMatchLocation.longitude;
		}

		const result = await callWeatherAPI(lat, long);
		console.log("result is" + result);

		let kitImage = "";

		if (result.gameTemp < 12) {
			kitImage = "vest";
		} else if (result.gameTemp > 18) {
			kitImage = "shortsleeve";
		} else {
			kitImage = "longsleeve";
		}

		document.querySelector(".temperature").textContent = result.gameTemp + "°C";
		document.querySelector(".descrip").textContent = result.weatherDesc;
		document.querySelector(".kit-img").src = `/img/kit-${kitImage}.png`;
	}

	document.querySelectorAll(".radio input").forEach((radio) => {
		radio.addEventListener("change", (e) => {
			handleWeatherData(e.target.value);
		});
	});
</script>

<style></style>

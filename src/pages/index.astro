---
// https://claude.ai/share/ff0ad59a-9510-4904-9638-e870e808854d
import { Temporal } from '@js-temporal/polyfill';
import HomeLayout from '../layouts/HomeLayout.astro'
import NextMatch from '../components/nextMatch.astro';

const barcaBaseURL = 'https://api.fc-barcelona.app/api/';

const nextMatchEndpoint = 'next-match';
const nextMatchURL = barcaBaseURL + nextMatchEndpoint;
const nextMatchResponse = await fetch(nextMatchURL);
const nextMatchArray = await nextMatchResponse.json();
const nextMatch = nextMatchArray.data;
const nextMatchId = nextMatch.id;

console.log(nextMatch)

const nextMatchDate = nextMatch.matchDate
const date = Temporal.Instant.from(nextMatchDate).toZonedDateTimeISO('Europe/Amsterdam').toPlainDate();

const day = date.toLocaleString('en-GB', { weekday: 'long' });
const month = date.toLocaleString('en-GB', { month: 'long' });
const year = date.year;
const ordinal = (n) => {
  const s = ['th','st','nd','rd'];
  const v = n % 100;
  return n + (s[(v - 20) % 10] || s[v] || s[0]);
};

const formatted = `${day}, ${ordinal(date.day)} of ${month} ${year}`;
console.log(formatted)

const calendarEndpoint = 'calendar?limit=50&offset=0';
const calendarURL = barcaBaseURL + calendarEndpoint;
const calendarResponse = await fetch(calendarURL);
const calendarArray = await calendarResponse.json();
const calendar = calendarArray.data;
const allMatches = calendar.matches;

// met behulp van: https://claude.ai/share/25b0ec6a-5a33-48c2-b95c-1ff0eaaf9f9b
let nextMatchCal = allMatches.filter(m => m.id >= nextMatchId)

const hToHEndpoint = 'h2h?team=Real+Madrid';
const hToHURL = barcaBaseURL + hToHEndpoint;
const hToHResponse = await fetch(hToHURL);
const hToHArray = await hToHResponse.json();
const hToH = hToHArray.data

// console.log(nextMatchCal)

---
<HomeLayout title="FC BARCELONA KIT">

	<NextMatch 
		match_date={formatted}
		home_img= {nextMatch.homeTeamImageUrl}
		home_team= {nextMatch.homeTeam}
		away_img={nextMatch.awayTeamImageUrl}
		away_team={nextMatch.awayTeam}
		venue={nextMatch.venue}/>

</HomeLayout>


